<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>XACT UI Store Integration Test</title>
    <style>
        body {
            font-family: monospace;
            padding: 20px;
            max-width: 1200px;
            margin: 0 auto;
        }
        .section {
            margin: 20px 0;
            padding: 15px;
            border: 1px solid #ccc;
            border-radius: 5px;
        }
        .section h3 {
            margin-top: 0;
            color: #333;
        }
        .pass {
            color: green;
            font-weight: bold;
        }
        .fail {
            color: red;
            font-weight: bold;
        }
        .info {
            color: blue;
        }
        #log {
            background: #f5f5f5;
            padding: 10px;
            border-radius: 3px;
            max-height: 400px;
            overflow-y: auto;
        }
        .log-entry {
            margin: 5px 0;
            padding: 2px 0;
        }
        button {
            padding: 10px 20px;
            margin: 5px;
            cursor: pointer;
            font-size: 14px;
        }
        button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
        #results {
            margin-top: 20px;
        }
        .result-item {
            padding: 8px;
            margin: 5px 0;
            border-radius: 3px;
        }
        .result-item.pass {
            background: #d4edda;
            border: 1px solid #c3e6cb;
        }
        .result-item.fail {
            background: #f8d7da;
            border: 1px solid #f5c6cb;
        }
    </style>
</head>
<body>
    <h1>XACT UI Store Integration Test</h1>
    
    <div class="section">
        <h3>Connection</h3>
        <button id="connectBtn">Run All Tests</button>
        <button id="disconnectBtn" disabled>Disconnect</button>
        <div id="connectionStatus">Not connected</div>
    </div>

    <div class="section">
        <h3>Test Results</h3>
        <div id="results"></div>
        <div id="summary"></div>
    </div>

    <div class="section">
        <h3>Log</h3>
        <div id="log"></div>
    </div>

    <script type="module">
        import { connect } from 'https://cdn.jsdelivr.net/npm/nats.ws@1.30.3/esm/nats.js';

        let nc = null;
        let js = null;
        let kv = null;
        const mirror = {};
        const subscriptions = new Map();
        const results = [];

        function log(message, type = 'info') {
            const logDiv = document.getElementById('log');
            const entry = document.createElement('div');
            entry.className = 'log-entry';
            entry.innerHTML = `<span class="${type}">[${new Date().toLocaleTimeString()}] ${message}</span>`;
            logDiv.appendChild(entry);
            logDiv.scrollTop = logDiv.scrollHeight;
            console.log(`[${type}]`, message);
        }

        function addResult(testName, passed, message) {
            const resultsDiv = document.getElementById('results');
            const item = document.createElement('div');
            item.className = `result-item ${passed ? 'pass' : 'fail'}`;
            item.innerHTML = `
                <strong>${testName}:</strong> ${passed ? 'PASSED' : 'FAILED'}
                ${message ? `<br>${message}` : ''}
            `;
            resultsDiv.appendChild(item);
            results.push({ name: testName, passed });
            updateSummary();
        }

        function updateSummary() {
            const summaryDiv = document.getElementById('summary');
            const passed = results.filter(r => r.passed).length;
            const total = results.length;
            summaryDiv.innerHTML = `
                <strong>Summary:</strong> ${passed}/${total} tests passed
                ${passed === total ? '<span class="pass">✓ All tests passed!</span>' : ''}
            `;
        }

        function normalizePath(path) {
            if (path === '/') return '/';
            return path.replace(/\/+$/, '');
        }

        function kvKey(path) {
            if (path === '/') return '>';
            
            if (path.startsWith('/')) {
                return path.substring(1);
            }
            
            return path;
        }

        function storePath(kvKey) {
            if (kvKey === '>') return '/';
            if (kvKey.startsWith('/')) {
                return kvKey;
            }
            return '/' + kvKey;
        }

        function get(path) {
            const normalized = normalizePath(path);
            const value = mirror[normalized];
            log(`Get: path=${path}, normalized=${normalized}, value=${JSON.stringify(value)}`, 'info');
            return value;
        }

        function waitForValue(path, timeoutMs = 3000) {
            const normalized = normalizePath(path);
            const startTime = Date.now();
            return new Promise((resolve, reject) => {
                const checkInterval = setInterval(() => {
                    const value = mirror[normalized];
                    if (value !== undefined) {
                        clearInterval(checkInterval);
                        resolve(value);
                    }
                    if (Date.now() - startTime > timeoutMs) {
                        clearInterval(checkInterval);
                        resolve(undefined);
                    }
                }, 100);
            });
        }

        function applyKvEntry(e) {
            const path = storePath(e.key);
            log(`Received KV entry: key=${e.key}, path=${path}, operation=${e.operation}`, 'info');
            
            if (e.operation === 'DEL' || e.operation === 'PURGE') {
                delete mirror[path];
                log(`Deleted entry at: ${path}`, 'info');
                return;
            }
            
            const decoder = new TextDecoder();
            const value = JSON.parse(decoder.decode(e.value));
            mirror[path] = value;
            log(`Stored value in mirror: ${path} = ${JSON.stringify(value)}`, 'info');
            
            log(`Current mirror keys: ${Object.keys(mirror).join(', ')}`, 'info');
        }

        async function watchPrefix(prefix) {
            let watcher = null;
            let stopped = false;
            let timeout = null;

            try {
                const watchOptions = {
                    key: kvKey(prefix),
                    ignoreDeletes: false,
                };
                watcher = await kv.watch(watchOptions);
                log(`Watch started for prefix: ${prefix}`, 'info');

                timeout = setTimeout(() => {
                    if (!stopped) {
                        log(`Watch timeout for prefix: ${prefix}, received ${Object.keys(mirror).length} entries`, 'info');
                    }
                }, 5000);

                for await (const e of watcher) {
                    if (stopped) break;
                    applyKvEntry(e);
                }
            } catch (error) {
                if (!stopped && error.message !== 'Break Interrupted') {
                    log(`Watch error for prefix: ${prefix}: ${error.message}`, 'fail');
                }
            } finally {
                if (timeout) {
                    clearTimeout(timeout);
                }
            }

            return () => {
                stopped = true;
                try {
                    if (watcher && typeof watcher.stop === 'function') {
                        watcher.stop();
                        log(`Watch stopped for prefix: ${prefix}`, 'info');
                    }
                } catch (e) {
                    log(`Error stopping watch: ${e.message}`, 'fail');
                }
            };
        }

        async function connectNats(opts) {
            if (nc) return;
            nc = await connect({ servers: opts.servers });
            js = nc.jetstream();
            kv = await js.views.kv(opts.kvBucket);
        }

        async function disconnectNats() {
            if (!nc) return;
            for (const stop of subscriptions.values()) {
                stop();
            }
            subscriptions.clear();
            await nc.close();
            nc = null;
            js = null;
            kv = null;
        }

        function subscribePath(path) {
            if (!kv) throw new Error("NATS not connected");
            const normalized = normalizePath(path);
            const kvKeyVal = kvKey(normalized);
            
            log(`Subscribing: path=${path}, normalized=${normalized}, kvKey=${kvKeyVal}`, 'info');
            
            let stop = subscriptions.get(normalized);
            if (!stop) {
                stop = watchPrefix(normalized);
                subscriptions.set(normalized, stop);
            } else {
                log(`Already subscribed to: ${normalized}`, 'info');
            }
        }

        function unsubscribePath(path) {
            const normalized = normalizePath(path);
            const stop = subscriptions.get(normalized);
            if (stop) {
                log(`Unsubscribing: ${normalized}`, 'info');
                stop();
                subscriptions.delete(normalized);
                log(`Unsubscribed: ${normalized}`, 'info');
            } else {
                log(`No subscription found for: ${normalized}`, 'info');
            }
        }

        function walkTree() {
            const root = { path: '/', children: [] };
            const index = new Map([['/', root]]);
            for (const path of Object.keys(mirror)) {
                if (!path) continue;
                const segments = path.split('/').filter(Boolean);
                let current = root;
                let currentPath = '';
                for (const segment of segments) {
                    currentPath += '/' + segment;
                    let node = index.get(currentPath);
                    if (!node) {
                        node = { path: currentPath, children: [] };
                        index.set(currentPath, node);
                        current.children.push(node);
                    }
                    current = node;
                }
            }
            return root;
        }

        async function sleep(ms) {
            return new Promise(resolve => setTimeout(resolve, ms));
        }

        async function runTests() {
            const connectBtn = document.getElementById('connectBtn');
            const disconnectBtn = document.getElementById('disconnectBtn');
            const statusDiv = document.getElementById('connectionStatus');

            connectBtn.disabled = true;
            disconnectBtn.disabled = true;

            try {
                document.getElementById('results').innerHTML = '';
                results.length = 0;
                updateSummary();
                log('Starting tests...', 'info');

                log('Test 1: Connecting to NATS...', 'info');
                try {
                    console.log('Connecting to ws://localhost:9222');
                    await connectNats({
                        servers: 'ws://localhost:9222',
                        kvBucket: 'rtdb',
                        timeout: 10000
                    });
                    statusDiv.innerHTML = '<span class="pass">Connected</span>';
                    log('Connected to NATS successfully', 'pass');
                    addResult('Connect to NATS', true);
                    disconnectBtn.disabled = false;
                } catch (error) {
                    console.error('Connection error:', error);
                    log(`Failed to connect: ${error.message}`, 'fail');
                    statusDiv.innerHTML = '<span class="fail">Connection failed</span>';
                    addResult('Connect to NATS', false, error.message);
                    connectBtn.disabled = false;
                    return;
                }

                await sleep(500);

                log('Test 2: Subscribing to building.floor1...', 'info');
                try {
                    subscribePath('building.floor1');
                    await sleep(2000);
                    log('Subscribed successfully', 'pass');
                    addResult('Subscribe to path', true);
                } catch (error) {
                    addResult('Subscribe to path', false, error.message);
                }

                log('Test 3: Getting value for building.floor1.temperature...', 'info');
                try {
                    const temp = await waitForValue('building.floor1.temperature');
                    if (temp !== undefined) {
                        log(`Got value: ${temp}`, 'pass');
                        addResult('Get value', true, `Temperature: ${temp}`);
                    } else {
                        log('Value is undefined', 'fail');
                        addResult('Get value', false, 'Value is undefined');
                    }
                } catch (error) {
                    addResult('Get value', false, error.message);
                }

                log('Test 4: Subscribing to multiple paths...', 'info');
                try {
                    subscribePath('/device1');
                    subscribePath('/building');
                    await sleep(500);
                    
                    const deviceStatus = await waitForValue('/device1/status');
                    const deviceTemp = await waitForValue('/device1.temperature');
                    const floor2Temp = await waitForValue('/building/floor2.temperature');
                    
                    unsubscribePath('/device1');
                    unsubscribePath('/building');
                    
                    const hasValues = deviceStatus || deviceTemp || floor2Temp;
                    addResult('Subscribe to multiple paths', hasValues, `Got values: ${hasValues}`);
                } catch (error) {
                    addResult('Subscribe to multiple paths', false, error.message);
                }

                log('Test 5: Walking tree...', 'info');
                try {
                    subscribePath('/');
                    await sleep(2000);
                    const tree = walkTree();
                    unsubscribePath('/');
                    
                    if (tree && tree.path === '/' && tree.children.length > 0) {
                        log(`Tree has ${tree.children.length} top-level items`, 'pass');
                        addResult('Walk tree', true, `${tree.children.length} items`);
                    } else {
                        addResult('Walk tree', false, 'Tree is empty or invalid');
                    }
                } catch (error) {
                    addResult('Walk tree', false, error.message);
                }

                log('All tests completed!', 'pass');

            } catch (error) {
                log(`Test suite error: ${error.message}`, 'fail');
            } finally {
                connectBtn.disabled = false;
            }
        }

        async function disconnect() {
            const disconnectBtn = document.getElementById('disconnectBtn');
            const statusDiv = document.getElementById('connectionStatus');

            try {
                await disconnectNats();
                statusDiv.innerHTML = '<span class="info">Disconnected</span>';
                disconnectBtn.disabled = true;
                log('Disconnected from NATS', 'info');
            } catch (error) {
                log(`Disconnect error: ${error.message}`, 'fail');
            }
        }

        const connectBtn = document.getElementById('connectBtn');
        const disconnectBtn = document.getElementById('disconnectBtn');

        if (connectBtn) {
            connectBtn.addEventListener('click', runTests);
            connectBtn.disabled = false;
        }

        if (disconnectBtn) {
            disconnectBtn.addEventListener('click', disconnect);
        }

        log('Test page loaded. Click "Run All Tests" to begin.');
    </script>
</body>
</html>
