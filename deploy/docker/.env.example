# Copy this file to deploy/docker/.env and replace every secret before use.

COMPOSE_PROJECT_NAME=xact

# Image published by .github/workflows/docker-image.yml.
XACT_IMAGE=ghcr.io/xact-iot/xact:latest

# Public site address handled by Caddy.
# Use a domain name for automatic public certificates, or localhost for local HTTP.
XACT_SITE_ADDRESS=localhost
HTTP_PORT=80
HTTPS_PORT=443

# PostgreSQL/TimescaleDB. The compose file binds this only to 127.0.0.1.
POSTGRES_USER=xact
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_DB=xact
POSTGRES_PORT=5432

# XACT production secrets. Use long random values.
JWT_SECRET=change-this-jwt-secret
NATS_INTERNAL_PASSWORD=change-this-nats-internal-password
NATS_BROWSER_TOKEN=change-this-nats-browser-token

# Optional first-run bootstrap password. Leave blank to use the UI bootstrap flow.
XACT_BOOTSTRAP_ADMIN_PASSWORD=

# Host directory for XACT plugins. Compose creates the directory if it is missing.
XACT_PLUGIN_DIR=./plugins

# Embedded MQTT defaults. Change these if MQTT is enabled in production.
EMBEDDED_MQTT_SERVER=yes
MQTT_URL=mqtt://127.0.0.1:1883
MQTT_PASSWORD=change-this-mqtt-password
MQTT_CLIENT_ENABLED=yes
MQTT_CLIENT_URL=mqtt://127.0.0.1:1883
MQTT_CLIENT_USERNAME=xact
MQTT_CLIENT_PASSWORD=change-this-mqtt-client-password

METRICS_RETENTION_DAYS=180
EVENT_RETENTION_DAYS=0
ENABLE_UNSAFE_SCHEDULER_TASKS=no
NATS_BROWSER_ALLOW_COMMANDS=no
